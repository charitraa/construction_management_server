# =====================================================
# ENVIRONMENT CONFIGURATION
# =====================================================
# Options: development, production
environment=development

# =====================================================
# SECURITY SETTINGS
# =====================================================
# SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY='django-insecure-change-this-in-production-use-openssl-rand-hex-32'

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=False

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# PostgreSQL Database Settings (for Docker)
POSTGRES_DB=construction_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database URL (for direct connection)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/construction_management

# Alternative: Individual database settings
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=construction_db
# DB_USER=construction_user
# DB_PASSWORD=construction_password
# DB_HOST=localhost
# DB_PORT=5432

# =====================================================
# REDIS CONFIGURATION
# =====================================================
# Redis Cache Settings
REDIS_URL=redis://localhost:6379/0

# Alternative: Individual Redis settings
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# =====================================================
# CORS SETTINGS
# =====================================================
# Frontend URL for CORS configuration
FRONTEND_URL="http://localhost:8080"

# Additional allowed origins for production (comma-separated)
# Only used in production mode
# CORS_ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
CORS_ALLOWED_ORIGINS="http://localhost:8080,http://localhost:3000"

# =====================================================
# EMAIL CONFIGURATION (OPTIONAL)
# =====================================================
# SMTP Settings for sending emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
EMAIL_FROM=noreply@construction-management.com

# =====================================================
# FILE STORAGE SETTINGS
# =====================================================
# Media files storage
MEDIA_URL=/media/
MEDIA_ROOT=./media

# Static files storage
STATIC_URL=/static/
STATIC_ROOT=./staticfiles

# =====================================================
# LOGGING SETTINGS
# =====================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/django.log

# =====================================================
# JWT SETTINGS
# =====================================================
# JWT Access Token Expiration (in minutes)
SIMPLE_JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# JWT Refresh Token Expiration (in days)
SIMPLE_JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# =====================================================
# RATE LIMITING SETTINGS
# =====================================================
# Rate limit for API requests (requests per minute)
RATE_LIMIT=60

# =====================================================
# TIMEZONE SETTINGS
# =====================================================
# Application timezone
TIME_ZONE=UTC

# Use timezone aware datetimes
USE_TZ=True

# =====================================================
# APPLICATION SETTINGS
# =====================================================
# Application name
APP_NAME=Construction Management API

# Application version
APP_VERSION=1.0.0

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# =====================================================
# MONITORING AND ANALYTICS (OPTIONAL)
# =====================================================
# Sentry for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Analytics tracking (optional)
# ANALYTICS_ID=UA-XXXXXXXXX-X
